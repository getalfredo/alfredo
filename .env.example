DEPLOY_USER=
DEPLOY_HOST=
DEPLOY_PORT=22

# User that owns and runs the app on the server (default: alfredo)
APP_USER=alfredo
# Set to "true" to create the user if it doesn't exist (default: false)
APP_USER_CREATE=false

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Set to "true" when using HTTPS (reverse proxy)
SECURE_COOKIES=false
